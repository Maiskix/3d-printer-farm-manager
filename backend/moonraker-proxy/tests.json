{
  "tests": [
    {
      "name": "OPTIONS запрос возвращает CORS-заголовки",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Запрос без IP возвращает ошибку 400",
      "method": "POST",
      "path": "/",
      "body": { "action": "status" },
      "expectedStatus": 400,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Запрос к недоступному IP возвращает connected:false",
      "method": "POST",
      "path": "/",
      "body": { "ip": "10.255.255.1", "port": "7125", "action": "info" },
      "expectedStatus": 200,
      "expectedBody": { "connected": false },
      "bodyMatcher": "partial"
    }
  ]
}
